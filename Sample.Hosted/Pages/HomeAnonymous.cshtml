@page "/"
@model Sample.Hosted.Pages.HomeAnonymous

@{
    var title = "Welcome";
    var options = Get.LayoutOptions.Full(string.Empty);
    options.CenterHorizontally = true;
    options.TextAlignment = BootstrapTextAlignment.TextCenter;
    options.Type = MainContentType.None;
    options.ColumnSize = BootstrapColumnSize.None;
    
    ViewData[Get.ViewDataKeys.Title] = title;
    ViewData[Get.ViewDataKeys.MainContentLayoutOptions] = options;

    var reactVersion = "19";
    var bootstrapVersion = "5.3";
    var tailwindVersion = "4.2";
    var viteVersion = "8";

    try 
    {
        var packageJsonPath = System.IO.Path.Combine(System.Environment.CurrentDirectory, "package.json");
        if (System.IO.File.Exists(packageJsonPath))
        {
            var json = System.Text.Json.JsonDocument.Parse(System.IO.File.ReadAllText(packageJsonPath));
            if (json.RootElement.TryGetProperty("dependencies", out var deps))
            {
                if (deps.TryGetProperty("react", out var r)) reactVersion = r.GetString()?.Replace("^", "")?.Replace("~", "") ?? reactVersion;
                if (deps.TryGetProperty("bootstrap", out var b)) bootstrapVersion = b.GetString()?.Replace("^", "")?.Replace("~", "") ?? bootstrapVersion;
                if (deps.TryGetProperty("tailwindcss", out var t)) tailwindVersion = t.GetString()?.Replace("^", "")?.Replace("~", "") ?? tailwindVersion;
            }
            if (json.RootElement.TryGetProperty("devDependencies", out var devDeps))
            {
                if (devDeps.TryGetProperty("vite", out var v)) viteVersion = v.GetString()?.Replace("^", "")?.Replace("~", "") ?? viteVersion;
            }
        }
    }
    catch { /* Ignore missing file/parsing errors and safely use defaults */ }
}

<div class="text-center py-2">
    <h2 class="fw-bold mb-2">Welcome to DRN Framework</h2>
    <p class="lead text-muted mb-4">A modern full-stack .NET framework with DDD architecture and React micro-frontends.</p>
</div>

<div data-js-hello-react-island></div>

@section Scripts {
    <script>
        let clickCount = 0;

        DRN.Onmount.registerFull('[data-js-hello-react-island]', function (options) {
            const island = DRN.React.mount('HelloReact', this, {
                title: 'DRN Micro-Frontends',
                versions: {
                    dotnet: @Json.Serialize(Environment.Version.ToString()),
                    react: @Json.Serialize(reactVersion),
                    bootstrap: @Json.Serialize(bootstrapVersion),
                    tailwind: @Json.Serialize(tailwindVersion),
                    vite: @Json.Serialize(viteVersion)
                },
                onReady: () => {
                    console.log('HelloReact component is ready');
                },
                onCardClick: () => {
                    clickCount++;
                    console.log(`Card clicked! Total clicks outside the component: ${clickCount}`);
                }
            });

            // Read back the merged props from the mounted island via getProps()
            console.log('[DRN] HelloReact island mounted props:', island?.getProps());

            // Cycle through titles with a smooth fade transition
            const titles = ['DRN Micro-Frontends', 'Build with Confidence', 'Islands Architecture', 'Full-Stack .NET'];
            let titleIndex = 0;
            const CYCLE_INTERVAL_MS = 4000;  // time between title changes
            const FADE_DURATION_MS = 500;    // matches CSS transition duration

            // Lexical 'this' captured via arrow function (replaces previous .bind(this))
            const cycleTitles = () => {
                if (!island || !island.getProps()) return;

                const shadow = this.shadowRoot;
                const badge = shadow?.querySelector('.hello-react-badge');

                // Phase 1: Fade out
                if (badge) badge.classList.add('is-transitioning');

                // Phase 2: Update title while faded out, then fade back in
                setTimeout(() => {
                    titleIndex = (titleIndex + 1) % titles.length;
                    island.update({ title: titles[titleIndex] });
                    if (badge) badge.classList.remove('is-transitioning');
                }, FADE_DURATION_MS);
            };

            // Store island as disposable for automatic cleanup on unmount
            options.disposable = island;
            this._drnIntervalId = setInterval(cycleTitles, CYCLE_INTERVAL_MS);
        }, function (options) {
            // Unregister: clean up interval on htmx swap / navigation
            if (this._drnIntervalId) clearInterval(this._drnIntervalId);
            
            // Call default unregister to dispose 'options.disposable'
            DRN.Onmount.unregister.call(this, options);
        });
    </script>
}