<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name" data-bs-theme="light">

@*
https://getbootstrap.com/docs/5.3/customize/color-modes/
https://getbootstrap.com/docs/5.3/examples/
https://getbootstrap.com/docs/5.3/examples/sidebars/

Vite is configured through package.json and vite.config.js.
When you trigger a build, it outputs compiled assets to wwwroot.
A manifest.json file is also created.
This file maps source files to their versioned outputs.

ASP.NET Core Tag Helpers—such as ViteLinkTagHelper and ViteScriptTagHelper—read from the manifest.
They automatically resolve the correct script and stylesheet paths for both development and production.
*@
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="DRN App">
    <meta name="author" content="Duran Serkan KILIÇ">
    <meta name="htmx-config" content='{"inlineScriptNonce":"@Context.GetNonce()"}'>
    <title>@ViewData[Get.ViewDataKeys.Title] - @ScopeContext.Settings.ApplicationName</title>
    <link rel="canonical" href="@(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)"/>
    <link href="/images/100.jpeg" rel="icon" type="image/x-icon"/>

    <!-- Preload -->
    @*https://icons.getbootstrap.com/#usage*@
    @*https://getbootstrap.com/docs/5.3/customize/overview/*@
    @*Bootstrap Icons merged into bootstrap.scss via Vite*@
    <link href="buildwww/lib/bootstrap/bootstrap.scss" rel="stylesheet" crossorigin="anonymous"/>
    <link href="buildwww/app/css/app.css" rel="stylesheet" crossorigin="anonymous"/>

    @*defines DRN.App, DRN.Utils, DRN.Onmount*@
    <script src="buildwww/app/js/appPreload.js" crossorigin="anonymous"></script>
    <script>
        DRN.App.Environment =  @Json.Serialize(ScopeContext.Settings.Environment.ToString());
        DRN.App.IsDev = @Json.Serialize(ScopeContext.Settings.IsDevelopmentEnvironment);
        DRN.App.CsrfToken = @Json.Serialize(Context.GetCsrfToken());
        DRN.App.DefaultCulture = @Json.Serialize(ScopeContext.Settings.Localization.DefaultCulture);
        DRN.App.SupportedCultures = @Json.Serialize(ScopeContext.Settings.Localization.SupportedCultures);
    </script>
    <!-- Preload -->

    <script src="buildwww/lib/htmx/htmxBundle.js" crossorigin="anonymous"></script>
    <script src="buildwww/lib/bootstrap/bootstrapBundle.js" crossorigin="anonymous"></script>

    @*
    https://www.jetbrains.com/help/rider/Installing_and_Removing_External_Software_Using_Node_Package_Manager.html
    https://www.jetbrains.com/help/rider/Configuring_JavaScript_Libraries.html#ws_js_configure_libraries_ts_definition_file
    
    //To enable intellisense
    Rider-> Settings -> Languages & Frameworks -> Javascript -> Libraries
       ->@types/bootstrap (Download as Global)
    *@

    <!-- Postload -->
    <script src="buildwww/app/js/appPostload.js" crossorigin="anonymous"></script>
    <script src="buildwww/lib/react/reactBundle.tsx"></script>
    <!-- Postload -->
</head>
<body class="d-flex flex-column bg-secondary-subtle vh-100" style="overflow: hidden;" hx-ext="safe-nonce" hx-boost="true" hx-history="false">
@RenderBody()

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>